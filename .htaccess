# Apache 설정 - OG 스크래퍼 봇 명시적 허용
# 일부 호스팅의 기본 봇 차단 정책 우회

<IfModule mod_rewrite.c>
    RewriteEngine On

    # OG 스크래퍼 봇은 항상 허용 (다른 봇 차단 룰보다 위에 위치해야 함)
    RewriteCond %{HTTP_USER_AGENT} (facebookexternalhit|Facebot|Twitterbot|KakaoTalk|kakaotalk|Daum|TelegramBot|LinkedInBot|Slackbot|Discordbot|WhatsApp|Googlebot|Bingbot|Yeti) [NC]
    RewriteRule ^ - [L]
</IfModule>

# OG 이미지 등 정적 파일에 정확한 MIME 타입 설정
<IfModule mod_mime.c>
    AddType image/png .png
    AddType image/jpeg .jpg .jpeg
    AddType image/svg+xml .svg
    AddType image/webp .webp
</IfModule>

# 캐시 정책 — OG 이미지는 짧게 (재배포 시 갱신 빠르게)
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png "access plus 1 hour"
    ExpiresByType image/jpeg "access plus 1 hour"
    ExpiresByType image/svg+xml "access plus 1 hour"
    ExpiresDefault "access plus 1 day"
</IfModule>

# 일부 호스팅이 PHP를 캐싱하는 것 방지 (OG 메타 동적 변경 가능)
<FilesMatch "\.(php)$">
    Header set Cache-Control "no-cache, must-revalidate"
</FilesMatch>

# .env, .git 등 민감 파일 접근 차단
<FilesMatch "^\.(env|git|gitignore|htaccess)">
    Require all denied
</FilesMatch>

<FilesMatch "\.(example|md|7z|zip|xls|xlsx|pptx)$">
    Require all denied
</FilesMatch>
